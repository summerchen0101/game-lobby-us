@charset "utf-8";

.voice-visualizer__buttons-container { display: flex; justify-content: cent=
er; align-items: center; gap: 15px 20px; flex-wrap: wrap; margin-bottom: 40=
px; }

.voice-visualizer__btn-center { box-sizing: border-box; flex-shrink: 0; wid=
th: 60px; height: 60px; padding: 0px; display: flex; justify-content: cente=
r; align-items: center; border-radius: 50%; background-color: rgb(255, 255,=
 255); border: 4px solid rgb(197, 197, 197); outline: none; cursor: pointer=
; transition: border-color 0.3s, background-color 0.3s; }

.voice-visualizer__btn-center:disabled { opacity: 0.85; cursor: default; }

.voice-visualizer__btn-center:hover { background-color: rgb(234, 234, 234);=
 border: 4px solid rgb(159, 159, 159); }

.voice-visualizer__btn-center > img { width: auto; height: 50%; max-height:=
 30px; }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause { backgrou=
nd-color: rgb(255, 48, 48); }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause:hover { ba=
ckground-color: rgb(255, 79, 79); }

.voice-visualizer__btn-center.voice-visualizer__btn-center-pause > img { he=
ight: 50%; max-height: 16px; }

.voice-visualizer__btn-center.voice-visualizer__btn-center--border-transpar=
ent { border-color: transparent; }

.voice-visualizer__btn-center.voice-visualizer__btn-center--border-transpar=
ent:hover { background-color: rgb(255, 255, 255); }

.voice-visualizer__btn-left { box-sizing: border-box; flex-shrink: 0; width=
: 60px; height: 60px; padding: 0px; display: flex; justify-content: center;=
 align-items: center; border-radius: 50%; background-color: rgb(255, 48, 48=
); border: 4px solid rgb(197, 197, 197); outline: none; cursor: pointer; tr=
ansition: border-color 0.3s, background-color 0.3s, opacity 0.3s; }

.voice-visualizer__btn-container { min-width: 100px; display: flex; justify=
-content: flex-end; }

.voice-visualizer__btn-left:hover { background-color: rgb(255, 79, 79); }

.voice-visualizer__btn-left:disabled { opacity: 0.6; background-color: rgb(=
255, 48, 48); cursor: default; }

