# 可選：檔期主題 id，對應 theme-seasonal.css 的 [data-theme="…"]（不設則用預設 palette）
# VITE_APP_THEME=cny

# 後端 API 根（不帶尾隨斜線）。本機可透過 Vite proxy 或指向 staging。
VITE_API_BASE=

# 設為 true 則不呼叫真實 API，用內建假資料（僅供本機介面與殼層測試）
VITE_API_USE_MOCK=true

# 可選：啟用 dev server 時把 /api 代理到此網域（不設則不啟用 proxy，亦可用 VITE_API_BASE 直連）
# VITE_DEV_PROXY=https://api.example.com

# 遊戲若未單獨指定 openInNewWindow，則用此：true=預設新分頁
VITE_OPEN_GAMES_IN_NEW_WINDOW=false

# 以下可選，覆寫預設 REST 相對路徑（以 VITE_API_BASE 為前綴）
# VITE_API_PATH_AUTH_REGISTER=/api/auth/register
# VITE_API_PATH_AUTH_LOGIN=/api/auth/login
# VITE_API_PATH_LOBBY_GAMES=/api/lobby/games
# VITE_API_PATH_USER_ME=/api/user/me
# VITE_API_PATH_PAYMENT_DEPOSIT=/api/payment/deposit

# 大廳「Single1 (Alpha)」內嵌試玩用 Unity WebGL URL（不設則用內建 alpha 預設）
# VITE_UNITY_DEMO_URL=https://unityweb-alpha.ffglobaltech.com/0000/Single1/index.html

# 大廳主視覺圖 URL（不設則用內建預設圖）
# VITE_LOBBY_HERO_IMAGE=https://example.com/hero.webp

# Trustpilot Business Unit ID（不設則大廳不顯示評價區塊）
# VITE_TRUSTPILOT_BUSINESS_UNIT_ID=

# 浮動「領取獎勵」按鈕導向路徑（預設 /profile）
# VITE_FLOATING_CTA_PATH=/profile
